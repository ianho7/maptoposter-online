{
  "name": "maptoposter-online",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "paraglide-js compile --project ./project.inlang && tsc -b && vite build",
    "build:wasm": "cd wasm && powershell.exe -ExecutionPolicy Bypass -File build.ps1",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "fix": "oxfmt src/ && oxlint --fix src/",
    "preview": "vite preview",
    "scan:images": "powershell.exe -ExecutionPolicy Bypass -File scripts/scan-images.ps1"
  },
